<?xml version="1.0" encoding="UTF-8"?>
<ehcache xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://www.ehcache.org/ehcache.xsd"
         updateCheck="false">

    <diskStore path="java.io.tmpdir/ehcache-order-service"/>

    <defaultCache
        maxEntriesLocalHeap="1000"
        maxEntriesLocalDisk="5000"
        eternal="false"
        timeToIdleSeconds="300"
        timeToLiveSeconds="600"
        diskExpiryThreadIntervalSeconds="300"
        memoryStoreEvictionPolicy="LRU">
        <persistence strategy="localTempSwap"/>
    </defaultCache>

    <cache name="com.example.orderservice.entity.Order"
           maxEntriesLocalHeap="500"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.OrderItem"
           maxEntriesLocalHeap="1000"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.OrderMaterial"
           maxEntriesLocalHeap="1000"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.OrderOperation"
           maxEntriesLocalHeap="2000"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.Workshop"
           maxEntriesLocalHeap="50"
           timeToIdleSeconds="600"
           timeToLiveSeconds="3600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.OrderStage"
           maxEntriesLocalHeap="500"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.Payment"
           maxEntriesLocalHeap="500"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.OrderComment"
           maxEntriesLocalHeap="500"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.FileAttachment"
           maxEntriesLocalHeap="500"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.clientservice.entity.Client"
           maxEntriesLocalHeap="200"
           timeToIdleSeconds="600"
           timeToLiveSeconds="3600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.employeeservice.entity.Employee"
           maxEntriesLocalHeap="200"
           timeToIdleSeconds="600"
           timeToLiveSeconds="3600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.materialservice.entity.Material"
           maxEntriesLocalHeap="200"
           timeToIdleSeconds="600"
           timeToLiveSeconds="3600"
           memoryStoreEvictionPolicy="LRU"/>

    <cache name="com.example.orderservice.entity.Order.items"
           maxEntriesLocalHeap="500"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"/>

    <cache name="com.example.orderservice.entity.Order.materials"
           maxEntriesLocalHeap="500"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"/>

    <cache name="com.example.orderservice.entity.OrderItem.materials"
           maxEntriesLocalHeap="1000"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"/>

    <cache name="com.example.orderservice.entity.OrderItem.operations"
           maxEntriesLocalHeap="2000"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"/>

    <cache name="com.example.orderservice.entity.Workshop.orderStages"
           maxEntriesLocalHeap="200"
           timeToIdleSeconds="300"
           timeToLiveSeconds="600"/>

    <cache name="com.example.orderservice.entity.Workshop.operationIds"
           maxEntriesLocalHeap="50"
           timeToIdleSeconds="600"
           timeToLiveSeconds="3600"/>
</ehcache>
